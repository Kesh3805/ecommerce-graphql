// Additional Prisma Schema for Merchandising & Product Discovery
// Append this to your existing schema.prisma

//////////////////////////////////////////////////////
// ENHANCED CATEGORIES (Replace existing if needed)
//////////////////////////////////////////////////////

model EnhancedCategory {
  category_id      Int      @id @default(autoincrement())
  store_id         Int
  store            Store    @relation(fields: [store_id], references: [store_id])

  // Hierarchy
  parent_id        Int?
  parent           EnhancedCategory?  @relation("CategoryHierarchy", fields: [parent_id], references: [category_id])
  children         EnhancedCategory[] @relation("CategoryHierarchy")
  path             String             // Materialized path: "1/5/12"
  depth            Int      @default(0)

  // Core Data
  name             String
  slug             String
  description      String?

  // Display
  position         Int      @default(0)
  is_visible       Boolean  @default(true)
  image_url        String?
  icon             String?

  // SEO
  meta_title       String?
  meta_description String?

  // Metadata
  metadata         Json     @default("{}")

  // Timestamps
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  products         EnhancedProductCategory[]
  filters          CategoryFilter[]
  section_items    SectionCategory[]

  @@unique([store_id, slug])
  @@unique([path])
  @@index([store_id])
  @@index([parent_id])
  @@index([slug])
  @@map("enhanced_categories")
}

model EnhancedProductCategory {
  id           Int               @id @default(autoincrement())
  product_id   Int
  product      Product           @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  category_id  Int
  category     EnhancedCategory  @relation(fields: [category_id], references: [category_id], onDelete: Cascade)
  is_primary   Boolean           @default(false)
  position     Int               @default(0)

  @@unique([product_id, category_id])
  @@index([product_id])
  @@index([category_id])
  @@map("enhanced_product_categories")
}

model CategoryFilter {
  filter_id      Int              @id @default(autoincrement())
  category_id    Int
  category       EnhancedCategory @relation(fields: [category_id], references: [category_id], onDelete: Cascade)
  attribute_key  String
  filter_type    String           // 'checkbox', 'range', 'color', 'size'
  display_name   String
  position       Int              @default(0)
  is_visible     Boolean          @default(true)
  config         Json             @default("{}")

  @@unique([category_id, attribute_key])
  @@index([category_id])
  @@map("category_filters")
}

//////////////////////////////////////////////////////
// COLLECTIONS SYSTEM
//////////////////////////////////////////////////////

model Collection {
  collection_id    Int      @id @default(autoincrement())
  store_id         Int
  store            Store    @relation(fields: [store_id], references: [store_id])

  // Core Data
  name             String
  slug             String
  description      String?

  // Type
  collection_type  String   @default("manual") // 'manual', 'automated'

  // Display
  image_url        String?
  is_visible       Boolean  @default(true)
  position         Int      @default(0)

  // SEO
  meta_title       String?
  meta_description String?

  // Scheduling
  published_at     DateTime?
  unpublished_at   DateTime?

  // Timestamps
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  products         CollectionProduct[]
  rules            CollectionRule[]
  cache            CollectionProductCache[]
  section_items    SectionCollection[]

  @@unique([store_id, slug])
  @@index([store_id])
  @@index([collection_type])
  @@map("collections")
}

model CollectionProduct {
  id            Int        @id @default(autoincrement())
  collection_id Int
  collection    Collection @relation(fields: [collection_id], references: [collection_id], onDelete: Cascade)
  product_id    Int
  product       Product    @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  position      Int        @default(0)
  added_at      DateTime   @default(now())

  @@unique([collection_id, product_id])
  @@index([collection_id])
  @@index([product_id])
  @@map("collection_products")
}

model CollectionRule {
  rule_id       Int        @id @default(autoincrement())
  collection_id Int
  collection    Collection @relation(fields: [collection_id], references: [collection_id], onDelete: Cascade)
  rule_group    Int        @default(0) // For OR grouping

  // Rule Definition
  field         String     // 'price', 'category', 'attribute.color', 'tag'
  operator      String     // 'equals', 'not_equals', 'greater_than', etc.
  value         String
  value_type    String     @default("string") // 'string', 'number', 'boolean', 'array'

  created_at    DateTime   @default(now())

  @@index([collection_id])
  @@map("collection_rules")
}

model CollectionProductCache {
  id            Int        @id @default(autoincrement())
  collection_id Int
  collection    Collection @relation(fields: [collection_id], references: [collection_id], onDelete: Cascade)
  product_id    Int
  product       Product    @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  score         Float      @default(0)
  cached_at     DateTime   @default(now())

  @@unique([collection_id, product_id])
  @@index([collection_id, score(sort: Desc)])
  @@map("collection_product_cache")
}

//////////////////////////////////////////////////////
// STOREFRONT PAGES & SECTIONS
//////////////////////////////////////////////////////

model StorefrontPage {
  page_id          Int      @id @default(autoincrement())
  store_id         Int
  store            Store    @relation(fields: [store_id], references: [store_id])

  // Page Identity
  page_type        String   // 'homepage', 'landing', 'category_landing'
  slug             String?  // For non-homepage pages
  name             String

  // Status
  is_published     Boolean  @default(false)
  published_at     DateTime?

  // SEO
  meta_title       String?
  meta_description String?

  // Timestamps
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  sections         PageSection[]

  @@unique([store_id, page_type, slug])
  @@index([store_id])
  @@map("storefront_pages")
}

model PageSection {
  section_id       Int            @id @default(autoincrement())
  page_id          Int
  page             StorefrontPage @relation(fields: [page_id], references: [page_id], onDelete: Cascade)

  // Section Type
  section_type     String         // 'hero_banner', 'product_carousel', 'collection_carousel', 'category_grid', 'rich_text', 'image_grid'

  // Display
  title            String?
  subtitle         String?
  position         Int            @default(0)
  is_visible       Boolean        @default(true)

  // Configuration (type-specific settings)
  config           Json           @default("{}")

  // Scheduling
  visible_from     DateTime?
  visible_until    DateTime?

  // Timestamps
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  // Relations
  banners          HeroBanner[]
  collections      SectionCollection[]
  categories       SectionCategory[]

  @@index([page_id, position])
  @@map("page_sections")
}

model HeroBanner {
  banner_id        Int         @id @default(autoincrement())
  section_id       Int
  section          PageSection @relation(fields: [section_id], references: [section_id], onDelete: Cascade)

  // Content
  title            String?
  subtitle         String?
  cta_text         String?
  cta_link         String?

  // Media
  desktop_image_url String
  mobile_image_url  String?
  video_url         String?

  // Display
  position         Int         @default(0)
  text_color       String      @default("#FFFFFF")
  overlay_opacity  Float       @default(0.3)
  text_position    String      @default("center") // 'left', 'center', 'right'

  // Scheduling
  visible_from     DateTime?
  visible_until    DateTime?

  @@index([section_id, position])
  @@map("hero_banners")
}

model SectionCollection {
  id            Int         @id @default(autoincrement())
  section_id    Int
  section       PageSection @relation(fields: [section_id], references: [section_id], onDelete: Cascade)
  collection_id Int
  collection    Collection  @relation(fields: [collection_id], references: [collection_id], onDelete: Cascade)
  position      Int         @default(0)

  @@unique([section_id, collection_id])
  @@index([section_id])
  @@map("section_collections")
}

model SectionCategory {
  id               Int              @id @default(autoincrement())
  section_id       Int
  section          PageSection      @relation(fields: [section_id], references: [section_id], onDelete: Cascade)
  category_id      Int
  category         EnhancedCategory @relation(fields: [category_id], references: [category_id], onDelete: Cascade)
  position         Int              @default(0)
  custom_image_url String?

  @@unique([section_id, category_id])
  @@index([section_id])
  @@map("section_categories")
}

